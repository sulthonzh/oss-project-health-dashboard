{
  "name": "oss-project-health-dashboard",
  "version": "1.3.0",
  "description": "One-command OSS project health analysis dashboard with bus factor, contributor diversity, response time, and sustainability metrics",
  "main": "dist/index.js",
  "bin": {
    "oss-health-check": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/enterprise-cli.ts src/demo-cli.ts --format cjs --external chalk,commander,octokit,cli-table3",
    "dev": "tsup src/index.ts src/enterprise-cli.ts src/demo-cli.ts --format cjs --external chalk,commander,octokit,cli-table3 --watch",
    "test": "node --test test/test.mjs",
    "test:coverage": "c8 node --test test/test.mjs",
    "lint": "eslint src/",
    "prepare": "npm run build",
    "enterprise": "node dist/enterprise-cli.js",
    "demo": "node dist/demo-cli.js",
    "test:standalone": "npx tsc --outDir dist-test --module commonjs --target ES2020 --esModuleInterop --moduleResolution node src/config-manager.ts src/health-analyzer.ts && node --test test/test.mjs && rm -rf dist-test"
  },
  "keywords": [
    "oss",
    "open-source",
    "health-check",
    "dashboard",
    "bus-factor",
    "contributor-diversity",
    "project-analytics",
    "github-analysis",
    "sustainability"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.0.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.0.0",
    "octokit": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./analyzer": {
      "require": "./dist/health-analyzer.js",
      "default": "./dist/health-analyzer.js"
    },
    "./reporter": {
      "require": "./dist/dashboard-reporter.js",
      "default": "./dist/dashboard-reporter.js"
    }
  },
  "prepublishOnly": "npm run build && npm test",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/oss-project-health-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/sulthonzh/oss-project-health-dashboard/issues"
  },
  "homepage": "https://github.com/sulthonzh/oss-project-health-dashboard#readme"
}
